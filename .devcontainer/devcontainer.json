{
  "name": "Healthcare IoT Testbed Dev",
  "dockerComposeFile": "docker-compose.yaml",
  "service": "devcontainer",
  "workspaceFolder": "/workspaces/Healthcare-IoT-Testbed",

  "features": {
    "ghcr.io/devcontainers/features/aws-cli:1": {},
    "ghcr.io/devcontainers/features/terraform:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.14"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    },
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installOhMyZsh": false,
      "configureZshAsDefaultShell": false
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "hashicorp.terraform",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "amazonwebservices.aws-toolkit-vscode",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "dbaeumer.vscode-eslint",
        "github.vscode-github-actions"
      ]
    }
  },

  "containerEnv": {
    "AWS_CONFIG_FILE": "${containerWorkspaceFolder}/.devcontainer/aws/config",
    "AWS_PROFILE": "Healthcare-IoT-Dev",
    "LOCALSTACK_ENDPOINT": "http://localstack:4566"
  },

  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y jq curl && pip install --upgrade pip && cd ${containerWorkspaceFolder}/Platform/services/web && npm install",
  "postStartCommand": "bash ${containerWorkspaceFolder}/.devcontainer/localstack/setup-localstack.sh",

  "remoteUser": "vscode"
}
